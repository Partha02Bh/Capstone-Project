package com.example.demo.exception;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ControllerAdvice;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.context.request.WebRequest;
import java.time.LocalDateTime;
import java.util.HashMap;
import java.util.Map;

// This annotation makes this class the "Safety Net" for the whole app
@ControllerAdvice
public class GlobalExceptionHandler {

    // 1. Handle specific "User Not Found" or "Logic" errors
    @ExceptionHandler(RuntimeException.class)
    public ResponseEntity<Object> handleRuntimeException(RuntimeException ex, WebRequest request) {
        Map<String, Object> body = new HashMap<>();
        body.put("timestamp", LocalDateTime.now());
        body.put("message", ex.getMessage());
        body.put("status", HttpStatus.BAD_REQUEST.value()); // 400 Error

        return new ResponseEntity<>(body, HttpStatus.BAD_REQUEST);
    }

    // 2. Handle unexpected crashes (NullPointer, etc.)
    @ExceptionHandler(Exception.class)
    public ResponseEntity<Object> handleGlobalException(Exception ex, WebRequest request) {
        Map<String, Object> body = new HashMap<>();
        body.put("timestamp", LocalDateTime.now());
        body.put("message", "An unexpected internal error occurred");
        body.put("details", ex.getMessage()); // Remove this line in production for security!
        body.put("status", HttpStatus.INTERNAL_SERVER_ERROR.value()); // 500 Error

        return new ResponseEntity<>(body, HttpStatus.INTERNAL_SERVER_ERROR);
    }
}